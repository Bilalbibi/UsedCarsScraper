<Window x:Class="UsedCarsScraper.CustomMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Message" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="ToolWindow" ShowInTaskbar="False"
        MinWidth="320" MaxWidth="500"
        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Icon & Message -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,15">
            <ContentControl x:Name="MessageIcon" Width="32" Height="32" Margin="0,0,15,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="MessageText" TextWrapping="Wrap" VerticalAlignment="Center" 
                       FontSize="14" Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
        </StackPanel>

        <!-- Buttons Container -->
        <WrapPanel x:Name="ButtonPanel" Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
    </Grid>
</Window>