<Window x:Class="UsedCarsScraper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        x:Name="RootWindow"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:standVirtualModels="clr-namespace:UsedCarsScraper.StandVirtualModels"
        xmlns:models="clr-namespace:UsedCarsScraper.LeBonCoinModels"
        mc:Ignorable="d"
        Loaded="Window_Loaded" 
        Closing="Window_Closing" 
        Title="UsedCarsScraper" Height="750" Width="1450"
        Icon="/Images/logo.png"
        Background="#F3F4F6"
        WindowStartupLocation="CenterScreen">

   <Window.Resources>
       <!-- App Core Colors -->
       <SolidColorBrush x:Key="Primary" Color="#4F46E5"/>
       <SolidColorBrush x:Key="Danger" Color="#EF4444"/>
       <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
       <SolidColorBrush x:Key="BorderColor" Color="#E5E7EB"/>
       
       <!-- Theme Colors -->
       <SolidColorBrush x:Key="LeboncoinColor" Color="#FF6E14"/>
       <SolidColorBrush x:Key="LaCentraleColor" Color="#E30613"/>

       <Style TargetType="Button">
           <Setter Property="Padding" Value="10,5"/>
           <Setter Property="Margin" Value="3"/>
           <Setter Property="FontWeight" Value="SemiBold"/>
           <Setter Property="Foreground" Value="White"/>
           <Setter Property="Background" Value="{StaticResource Primary}"/>
           <Setter Property="BorderThickness" Value="0"/>
           <Setter Property="Cursor" Value="Hand"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="Button">
                       <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                           <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                       </Border>
                       <ControlTemplate.Triggers>
                           <Trigger Property="IsMouseOver" Value="True">
                               <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>
       <Style TargetType="ComboBox">
           <Setter Property="Background" Value="Transparent"/>
           <Setter Property="BorderThickness" Value="0"/>
           <Setter Property="Padding" Value="5,2"/>
       </Style>
       <Style TargetType="DatePicker">
           <Setter Property="Background" Value="Transparent"/>
           <Setter Property="BorderThickness" Value="0"/>
       </Style>
       <Style x:Key="Card" TargetType="Border">
           <Setter Property="Background" Value="{StaticResource CardBg}"/>
           <Setter Property="CornerRadius" Value="10"/>
           <Setter Property="Padding" Value="10"/>
           <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
           <Setter Property="BorderThickness" Value="1"/>
       </Style>
   </Window.Resources>

   <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="Transparent" BorderThickness="0">

            <TabControl.Resources>
                <!-- Modern Tab Style -->
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="bd" Background="Transparent" Padding="12,6" CornerRadius="8" Margin="2">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="{TemplateBinding Tag}" Margin="0,0,6,0" FontFamily="Segoe MDL2 Assets"/>
                                        <ContentPresenter ContentSource="Header"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#E0E7FF"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ======================= TAB 1: STANDVIRTUAL ======================= -->
            <TabItem Header="Standvirtual Scraper 1.01" Tag="">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+" Width="30" Click="AddRow_Click"/>
                            <Button Content="-" Width="30" Click="DeleteRow_Click" Background="{StaticResource Danger}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <DataGrid x:Name="StandvirtualGrid" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False"
                                  RowHeight="34"
                                  GridLinesVisibility="All"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource BorderColor}"
                                  SelectionMode="Extended"
                                  SelectionUnit="CellOrRowHeader"
                                  AlternatingRowBackground="#F9FAFB"
                                  AlternationCount="2"
                                  HorizontalScrollBarVisibility="Auto">

                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                            </DataGrid.Resources>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                    <Setter Property="BorderThickness" Value="0.5"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#EEF2FF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F3F4F6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Background" Value="#F9FAFB"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Make" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding StandVirtualConfig.Makes, ElementName=RootWindow}"  
                                                      SelectedItem="{Binding StandVirtualMake}" 
                                                      DisplayMemberPath="Name"
                                                      DataContext="{Binding}" 
                                                      SelectionChanged="Make_SelectionChanged" 
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Model" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type standVirtualModels:StandVirtualInputModel}">
                                            <ComboBox ItemsSource="{Binding Models}" 
                                                      SelectedItem="{Binding StandVirtualModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                      DisplayMemberPath="Name"
                                                      SelectionChanged="Model_SelectionChanged"
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="SubModel" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type standVirtualModels:StandVirtualInputModel}">
                                            <ComboBox ItemsSource="{Binding SubModels}" 
                                                      SelectedItem="{Binding StandVirtualSubModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                      DisplayMemberPath="Name"
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Energy Type" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type standVirtualModels:StandVirtualInputModel}">
                                            <ComboBox ItemsSource="{Binding StandVirtualConfig.FuelTypes, ElementName=RootWindow}" 
                                                      SelectedValue="{Binding FuelType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                      SelectedValuePath="Key"
                                                      DisplayMemberPath="Value"
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTextColumn Header="From Date" Binding="{Binding FromDate}" Width="75"/>
                                <DataGridTextColumn Header="To Date" Binding="{Binding ToDate}" Width="75"/>
                                <DataGridTextColumn Header="Min Price" Binding="{Binding PriceFrom}" Width="70"/>
                                <DataGridTextColumn Header="Max Price" Binding="{Binding PriceTo}" Width="70"/>
                                <DataGridTextColumn Header="Min KM" Binding="{Binding MileAgeFrom}" Width="65"/>
                                <DataGridTextColumn Header="Max KM" Binding="{Binding MileAgeTo}" Width="65"/>
                                
                                <DataGridTemplateColumn Header="Batt From" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type standVirtualModels:StandVirtualInputModel}">
                                            <TextBox Text="{Binding BatteryCapacityFrom, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                     IsEnabled="{Binding IsElectric}" 
                                                     Background="Transparent" BorderThickness="0" 
                                                     VerticalContentAlignment="Center" Padding="4,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Batt To" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type standVirtualModels:StandVirtualInputModel}">
                                            <TextBox Text="{Binding BatteryCapacityTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                     IsEnabled="{Binding IsElectric}" 
                                                     Background="Transparent" BorderThickness="0" 
                                                     VerticalContentAlignment="Center" Padding="4,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTemplateColumn Header="Advertising date" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <DatePicker SelectedDate="{Binding AdvertisingDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                        BorderThickness="0" Background="Transparent" Padding="2"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTextColumn Header="Reg Year" Binding="{Binding RegistrationYear}" Width="65"/>
                                <DataGridCheckBoxColumn Header="VAT" Binding="{Binding Vat}" Width="40"/>
                                <DataGridTextColumn Header="Supplier" Binding="{Binding CompanySeller}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,15,0,0" Background="#F9FAFB">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <RadioButton x:Name="Daily" Content="Daily Scrape" GroupName="Freq" Margin="0,0,20,0" VerticalAlignment="Center" IsChecked="True"/>
                            <RadioButton x:Name="ThreeDays" Content="Every 3 Days" GroupName="Freq" Margin="0,0,20,0" VerticalAlignment="Center"/>
        
                            <Button x:Name="StartBtn" Content="START SCRAPING" Click="StartButton_Click"
                                    Background="{StaticResource Primary}"
                                    Padding="30,8" FontSize="14" Margin="10,0,0,0"/>

                            <Button x:Name="StopBtn" Content="STOP" Click="StopButton_Click"
                                    Background="{StaticResource Danger}"
                                    Padding="30,8" FontSize="14" Margin="10,0,0,0" IsEnabled="False"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ======================= TAB 2: LEBONCOIN ======================= -->
            <TabItem Header="Leboncoin Scraper 1.00" Tag="">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <!-- Unique names for Leboncoin buttons -->
                            <Button Content="+" Width="30" Click="LbAddRow_Click" Background="{StaticResource LeboncoinColor}"/>
                            <Button Content="-" Width="30" Click="LbDeleteRow_Click" Background="{StaticResource Danger}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <DataGrid x:Name="LeboncoinGrid" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False"
                                  RowHeight="34"
                                  GridLinesVisibility="All"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource BorderColor}"
                                  SelectionMode="Extended"
                                  SelectionUnit="CellOrRowHeader"
                                  AlternatingRowBackground="#F9FAFB"
                                  AlternationCount="2"
                                  HorizontalScrollBarVisibility="Auto">

                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                            </DataGrid.Resources>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                    <Setter Property="BorderThickness" Value="0.5"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <!-- Soft orange highlight for Leboncoin -->
                                            <Setter Property="Background" Value="#FFF1E6"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F3F4F6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Background" Value="#F9FAFB"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>
                                <!-- LEBONCOIN MAKE COLUMN -->
                                <DataGridTemplateColumn Header="Make" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:LeboncoinInputModel}">
                                            <ComboBox ItemsSource="{Binding LbConfig.BonCoinCarBrands, ElementName=RootWindow}"  
                                                      SelectedItem="{Binding Make, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                      DisplayMemberPath="Name" 
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- LEBONCOIN MODEL COLUMN -->
                                <DataGridTemplateColumn Header="Model" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:LeboncoinInputModel}">
                                            <ComboBox ItemsSource="{Binding Models}" 
                                                      SelectedItem="{Binding Model, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                      DisplayMemberPath="Name" 
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- LEBONCOIN ENERGY TYPE COLUMN -->
                                <DataGridTemplateColumn Header="Energy Type" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:LeboncoinInputModel}">
                                            <ComboBox ItemsSource="{Binding LbConfig.Fuels, ElementName=RootWindow}" 
                                                      SelectedItem="{Binding FuelType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                      DisplayMemberPath="Name"
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTextColumn Header="Min Price" Binding="{Binding PriceFrom}" Width="80"/>
                                <DataGridTextColumn Header="Max Price" Binding="{Binding PriceTo}" Width="80"/>
                                <DataGridTextColumn Header="Min KM" Binding="{Binding MileAgeFrom}" Width="75"/>
                                <DataGridTextColumn Header="Max KM" Binding="{Binding MileAgeTo}" Width="75"/>
                                <DataGridTextColumn Header="Puissance DIN Min" Binding="{Binding DinPowerFrom}" Width="120"/>
                                <DataGridTextColumn Header="Puissance DIN Max" Binding="{Binding DinPowerTo}" Width="120"/>
                                
                                <DataGridTemplateColumn Header="Advertising date" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <DatePicker SelectedDate="{Binding AdvertisingDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                        BorderThickness="0" Background="Transparent" Padding="2"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTextColumn Header="Reg Year" Binding="{Binding RegistrationYear}" Width="75"/>
                                <DataGridTextColumn Header="Supplier" Binding="{Binding CompanySeller}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,15,0,0" Background="#F9FAFB">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <RadioButton x:Name="LbDaily" Content="Daily Scrape" GroupName="LbFreq" Margin="0,0,20,0" VerticalAlignment="Center" IsChecked="True"/>
                            <RadioButton x:Name="LbThreeDays" Content="Every 3 Days" GroupName="LbFreq" Margin="0,0,20,0" VerticalAlignment="Center"/>
        
                            <Button x:Name="LbStartBtn" Content="START SCRAPING" Click="LbStartButton_Click"
                                    Background="{StaticResource LeboncoinColor}"
                                    Padding="30,8" FontSize="14" Margin="10,0,0,0"/>

                            <Button x:Name="LbStopBtn" Content="STOP" Click="LbStopButton_Click"
                                    Background="{StaticResource Danger}"
                                    Padding="30,8" FontSize="14" Margin="10,0,0,0" IsEnabled="False"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ======================= TAB 3: LA CENTRALE (NEW) ======================= -->
            <TabItem Header="La Centrale Scraper 1.00" Tag="">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+" Width="30" Click="LcAddRow_Click" Background="{StaticResource LaCentraleColor}"/>
                            <Button Content="-" Width="30" Click="LcDeleteRow_Click" Background="{StaticResource Danger}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <DataGrid x:Name="LaCentraleGrid" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False"
                                  RowHeight="34"
                                  GridLinesVisibility="All"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource BorderColor}"
                                  SelectionMode="Extended"
                                  SelectionUnit="CellOrRowHeader"
                                  AlternatingRowBackground="#F9FAFB"
                                  AlternationCount="2"
                                  HorizontalScrollBarVisibility="Auto">

                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                            </DataGrid.Resources>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                    <Setter Property="BorderThickness" Value="0.5"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <!-- Soft red highlight for La Centrale -->
                                            <Setter Property="Background" Value="#FDE8E9"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F3F4F6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Background" Value="#F9FAFB"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <!-- LA CENTRALE COLUMNS -->
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Make" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding LcConfig.Makes, ElementName=RootWindow}"  
                                                      SelectedItem="{Binding Make, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                      DisplayMemberPath="Name" 
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Model" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding Models}" 
                                                      SelectedItem="{Binding Model, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                      DisplayMemberPath="Name" 
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="SubModel" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding SubModels}"
                                                      SelectedItem="{Binding SubModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      DisplayMemberPath="Name"
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Energy Type" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding LcConfig.FuelTypes, ElementName=RootWindow}" 
                                                      SelectedValue="{Binding FuelType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                      SelectedValuePath="Key"
                                                      DisplayMemberPath="Value"
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTextColumn Header="Min Price" Binding="{Binding PriceFrom}" Width="80"/>
                                <DataGridTextColumn Header="Max Price" Binding="{Binding PriceTo}" Width="80"/>
                                <DataGridTextColumn Header="Min KM" Binding="{Binding MileAgeFrom}" Width="75"/>
                                <DataGridTextColumn Header="Max KM" Binding="{Binding MileAgeTo}" Width="75"/>
                                <DataGridTextColumn Header="Puissance DIN Min" Binding="{Binding DinPowerFrom}" Width="130"/>
                                <DataGridTextColumn Header="Puissance DIN Max" Binding="{Binding DinPowerTo}" Width="130"/>
                                
                                <DataGridTemplateColumn Header="Advertising date" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <DatePicker SelectedDate="{Binding AdvertisingDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                        BorderThickness="0" Background="Transparent" Padding="2"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTextColumn Header="Reg Year" Binding="{Binding RegistrationYear}" Width="75"/>
                                <DataGridTextColumn Header="Supplier" Binding="{Binding CompanySeller}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,15,0,0" Background="#F9FAFB">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <RadioButton x:Name="LcDaily" Content="Daily Scrape" GroupName="LcFreq" Margin="0,0,20,0" VerticalAlignment="Center" IsChecked="True"/>
                            <RadioButton x:Name="LcThreeDays" Content="Every 3 Days" GroupName="LcFreq" Margin="0,0,20,0" VerticalAlignment="Center"/>
        
                            <Button x:Name="LcStartBtn" Content="START SCRAPING" Click="LcStartButton_Click"
                                    Background="{StaticResource LaCentraleColor}"
                                    Padding="30,8" FontSize="14" Margin="10,0,0,0"/>

                            <Button x:Name="LcStopBtn" Content="STOP" Click="LcStopButton_Click"
                                    Background="{StaticResource Danger}"
                                    Padding="30,8" FontSize="14" Margin="10,0,0,0" IsEnabled="False"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ======================= TAB 4: LOG ======================= -->
            <TabItem Header="Log" Tag="&#xE8F2;">
                <Border Style="{StaticResource Card}" Margin="10">
                    <TextBox x:Name="LogTextBox" 
                             IsReadOnly="True" 
                             VerticalScrollBarVisibility="Auto" 
                             TextWrapping="Wrap"
                             FontFamily="Consolas" 
                             FontSize="13"
                             Background="#F9FAFB" 
                             BorderThickness="0" />
                </Border>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Margin="0,15,0,0">
            <TextBlock x:Name="ProgressLabel" 
                       Text="" 
                       FontWeight="SemiBold" 
                       Foreground="#6B7280" 
                       Margin="0,0,0,5" 
                       HorizontalAlignment="Left" />
            
            <ProgressBar x:Name="MainProgressBar" 
                         Height="10" 
                         Minimum="0" Maximum="100" 
                         Foreground="{StaticResource Primary}" 
                         Background="{StaticResource BorderColor}" 
                         BorderThickness="0"/>
        </StackPanel>

   </Grid>
</Window>
