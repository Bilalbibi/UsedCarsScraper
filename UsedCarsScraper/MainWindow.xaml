<Window x:Class="UsedCarsScraper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        x:Name="RootWindow"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:UsedCarsScraper.Models"
        mc:Ignorable="d"
        Loaded="Window_Loaded" 
        Title="UsedCarsScraper" Height="700" Width="1200"
        Icon="/Images/logo.png"
        Background="#F3F4F6"
        WindowStartupLocation="CenterScreen">

   <Window.Resources>
       <SolidColorBrush x:Key="Primary" Color="#4F46E5"/>
       <SolidColorBrush x:Key="Danger" Color="#EF4444"/>
       <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
       <SolidColorBrush x:Key="BorderColor" Color="#E5E7EB"/>

       <Style TargetType="Button">
           <Setter Property="Padding" Value="10,5"/>
           <Setter Property="Margin" Value="3"/>
           <Setter Property="FontWeight" Value="SemiBold"/>
           <Setter Property="Foreground" Value="White"/>
           <Setter Property="Background" Value="{StaticResource Primary}"/>
           <Setter Property="BorderThickness" Value="0"/>
           <Setter Property="Cursor" Value="Hand"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="Button">
                       <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                           <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                       </Border>
                       <ControlTemplate.Triggers>
                           <Trigger Property="IsMouseOver" Value="True">
                               <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>
       <Style TargetType="ComboBox">
           <Setter Property="Background" Value="Transparent"/>
           <Setter Property="BorderThickness" Value="0"/>
           <Setter Property="Padding" Value="5,2"/>
       </Style>
       <Style TargetType="DatePicker">
           <Setter Property="Background" Value="Transparent"/>
           <Setter Property="BorderThickness" Value="0"/>
       </Style>
       <Style x:Key="Card" TargetType="Border">
           <Setter Property="Background" Value="{StaticResource CardBg}"/>
           <Setter Property="CornerRadius" Value="10"/>
           <Setter Property="Padding" Value="10"/>
           <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
           <Setter Property="BorderThickness" Value="1"/>
       </Style>
   </Window.Resources>

   <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Background="Transparent" BorderThickness="0">

            <TabControl.Resources>
                <!-- Modern Tab Style -->
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="bd" Background="Transparent" Padding="12,6" CornerRadius="8" Margin="2">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="{TemplateBinding Tag}" Margin="0,0,6,0" FontFamily="Segoe MDL2 Assets"/>
                                        <ContentPresenter ContentSource="Header"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#E0E7FF"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- TAB 1 -->
            <TabItem Header="Standvirtual Scraper 1.00" Tag="">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+" Width="30" Click="AddRow_Click"/>
                            <Button Content="-" Width="30" Click="DeleteRow_Click" Background="{StaticResource Danger}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}">
                        <DataGrid x:Name="StandvirtualGrid" 
                                  AutoGenerateColumns="False" 
                                  CanUserAddRows="False"
                                  RowHeight="34"
                                  GridLinesVisibility="All"
                                  BorderThickness="1"
                                  BorderBrush="{StaticResource BorderColor}"
                                  SelectionMode="Extended"
                                  SelectionUnit="CellOrRowHeader"
                                  AlternatingRowBackground="#F9FAFB"
                                  AlternationCount="2"
                                  HorizontalScrollBarVisibility="Auto">

                            <!-- Remove blue selection -->
                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                            </DataGrid.Resources>

                            <!-- Cell Style -->
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                    <Setter Property="BorderThickness" Value="0.5"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#EEF2FF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F3F4F6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>

                            <!-- Row Style -->
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Background" Value="#F9FAFB"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter Property="Padding" Value="4,0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Make" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding AppConfig.Makes, ElementName=RootWindow}"  
                                                      SelectedItem="{Binding Make}" 
                                                      DisplayMemberPath="Name"
                                                      DataContext="{Binding}" 
                                                      SelectionChanged="Make_SelectionChanged" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="Model" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="{x:Type models:InputModel}">
                                            <ComboBox ItemsSource="{Binding Models}" 
                                                      SelectedItem="{Binding Model,Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                      DisplayMemberPath="Name"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTextColumn Header="From Date" Binding="{Binding FromDate}" Width="75"/>
                                <DataGridTextColumn Header="To Date" Binding="{Binding ToDate}" Width="75"/>
                                <DataGridTextColumn Header="Min Price" Binding="{Binding PriceFrom}" Width="70"/>
                                <DataGridTextColumn Header="Max Price" Binding="{Binding PriceTo}" Width="70"/>
                                <DataGridTextColumn Header="Min KM" Binding="{Binding MileAgeFrom}" Width="65"/>
                                <DataGridTextColumn Header="Max KM" Binding="{Binding MileAgeTo}" Width="65"/>
                                <DataGridTextColumn Header="Batt From" Binding="{Binding BatteryCapacityFrom}" Width="70"/>
                                <DataGridTextColumn Header="Batt To" Binding="{Binding BatteryCapacityTo}" Width="70"/>
                                
                                <!-- 1. NEW COLUMN: Advertising Date (Date Picker) -->
                                <DataGridTemplateColumn Header="Advertising date" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <DatePicker SelectedDate="{Binding AdvertisingDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                        BorderThickness="0" Background="Transparent" Padding="2"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Reg Year" Binding="{Binding RegistrationYear}" Width="65"/>
                                <DataGridCheckBoxColumn Header="VAT" Binding="{Binding Vat}" Width="40"/>
                                <DataGridTextColumn Header="Supplier" Binding="{Binding CompanySeller}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,15,0,0" Background="#F9FAFB">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <RadioButton x:Name="Daily" Content="Daily Scrape" GroupName="Freq" Margin="0,0,20,0" VerticalAlignment="Center"/>
                            <RadioButton x:Name="ThreeDays" Content="Every 3 Days" GroupName="Freq" Margin="0,0,20,0" VerticalAlignment="Center"/>
        
                            <Button Content="START SCRAPING" Click="StartButton_Click"
                                    Background="{StaticResource Primary}"
                                    Padding="30,8" 
                                    FontSize="14"
                                    Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- TAB 2 -->
            <!-- TAB 2 -->
            <TabItem Header="Log" Tag="&#xE8F2;">
                <Border Style="{StaticResource Card}" Margin="10">
                    <TextBox x:Name="LogTextBox" 
                             IsReadOnly="True" 
                             VerticalScrollBarVisibility="Auto" 
                             TextWrapping="Wrap"
                             FontFamily="Consolas" 
                             FontSize="13"
                             Background="#F9FAFB" 
                             BorderThickness="0" />
                </Border>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Margin="0,15,0,0">
            <TextBlock x:Name="ProgressLabel" 
                       Text="" 
                       FontWeight="SemiBold" 
                       Foreground="#6B7280" 
                       Margin="0,0,0,5" 
                       HorizontalAlignment="Left" />
            
            <ProgressBar x:Name="MainProgressBar" 
                         Height="10" 
                         Minimum="0" Maximum="100" 
                         Foreground="{StaticResource Primary}" 
                         Background="{StaticResource BorderColor}" 
                         BorderThickness="0"/>
        </StackPanel>

   </Grid>
</Window>